{
  "name": "ko-workbench",
  "version": "0.1.0",
  "description": "KO Workbench — EP-133 K.O. II workflow engine",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "keywords": [
    "ep-133",
    "ko-ii",
    "teenage-engineering",
    "sampler"
  ],
  "author": "phenomenon0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.koworkbench.app",
    "productName": "KO Workbench",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "wasm/**/*"
    ],
    "linux": {
      "category": "Audio",
      "executableName": "ko-workbench"
    }
  }
}
